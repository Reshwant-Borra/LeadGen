OPENAI_API_KEY=sk-...
# Optional: default is gpt-4o-mini
# OPENAI_MODEL=gpt-4o-mini
# OpenRouter or other OpenAI-compatible APIs:
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_MODEL=openai/gpt-4o-mini
#
# $0 inference (free tier; limits change — check vendor docs). Must support JSON mode for prompt 1.
# Groq OpenAI-compatible:
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_...
# OPENAI_MODEL=llama-3.3-70b-versatile
# (Pick a current Groq model that supports response_format json_object.)

# For --discover: Google Cloud / Maps Platform API key with "Places API (New)" enabled
# GOOGLE_PLACES_API_KEY=...
# Or use the same value as:
# GOOGLE_MAPS_API_KEY=...

# Optional: self-hosted Firecrawl — homepage fetch tries POST /v1/scrape first (JS/Playwright).
# If FIRECRAWL_API_URL is set in Windows "user environment variables" but you are not
# running Firecrawl, set FIRECRAWL_DISABLE=1 in .env.local (load_project_env strips the URL).
# Or leave FIRECRAWL_API_URL unset unless Firecrawl is actually running (e.g. docker on :3002).
# FIRECRAWL_DISABLE=1
# After: docker compose up in firecrawl repo → http://127.0.0.1:3002
# FIRECRAWL_API_URL=http://127.0.0.1:3002/v1
# FIRECRAWL_API_KEY=          # optional on self-host; required for api.firecrawl.dev
# FIRECRAWL_TIMEOUT=90         # seconds (default 90)
